# LLM API (选题评分 + 文章生成)
# 方式一：直接用 Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
#
# 方式二：用智谱 GLM Coding Plan（Anthropic 兼容 API，更便宜）
# ANTHROPIC_API_KEY=你的智谱API密钥
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# LLM_MODEL=glm-4.7
#
# 不设 ANTHROPIC_BASE_URL 则默认走 Anthropic 官方 API
# 不设 LLM_MODEL 则默认用 claude-sonnet-4-20250514

ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# LLM_MODEL=glm-4.7

# Google AI (Gemini / Nano Banana for cover images)
GOOGLE_AI_API_KEY=

# 微信公众号 (publish.js 使用，MVP 阶段可暂不配置)
WECHAT_APP_ID=
WECHAT_APP_SECRET=
